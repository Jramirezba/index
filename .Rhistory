# Cargar las librerÃ­as necesarias
library(ggplot2)
library(dplyr)
library(readxl)
# Calcular los porcentajes de cada categorÃ­a de ESTRATO dentro de cada ESTADO
data_porcentaje <- educacion %>%
count(Genero, Estrato) %>%
group_by(Genero) %>%
mutate(porcentaje = n / sum(n) * 100)
# Crear el diagrama de barras conjuntas con porcentajes
ggplot(data_porcentaje, aes(x = Genero, y = porcentaje, fill = Estrato)) +
geom_bar(stat = "identity", position = "dodge") +  # Usar "stack" si deseas barras apiladas
labs(title = "DistribuciÃ³n porcentual de Estrato por Genero",
x = "Genero",
y = "Porcentaje",
fill = "Estrato") +
theme_minimal() +
geom_text(aes(label = sprintf("%.1f%%", porcentaje)),
position = position_dodge(0.9),
vjust = -0.5,
size = 3.5)
# Cargar las bibliotecas necesarias
library(dplyr)
library(readxl)
library(kableExtra)
# Crear una tabla de contingencia con FUNCION y ESTRATO
table_Genero_Estrato <- table(educacion$Genero, educacion$Estrato)
# Convertir la tabla a un data frame para facilitar el manejo de datos
table_df <- as.data.frame.matrix(table_Genero_Estrato)
# Calcular el total general para las frecuencias relativas
total_fi <- sum(table_df)  # Total general para todas las celdas
# Calcular las frecuencias relativas
table_df <- table_df / total_fi  # Dividir cada valor por el total general para obtener la frecuencia relativa
# Calcular los totales de frecuencia relativa por fila y columna
table_df$Total <- rowSums(table_df)  # Totales por fila (frecuencias relativas)
total_column <- colSums(table_df)  # Totales por columna (frecuencias relativas)
# AÃ±adir una fila de totales al final de la tabla
table_df <- rbind(table_df, Total = total_column)
# Mostrar la tabla con kableExtra, aplicando color solo a la fila de Totales
tabla_final %>%
kable("html", caption = "Tabla de Frecuencias Relativas de Genero vs Estrato") %>%
kable_styling(bootstrap_options = c("striped", "hover", "condensed", "responsive"),
full_width = F, position = "center") %>%
row_spec(nrow(tabla_final), bold = T, color = "red", background = "darkgreen")  # Resaltar solo la fila de Totales
library(ggplot2)
library(dplyr)
# Datos agrupados
edad <- data.frame(
mi = c(28.5, 33.5, 38.5, 43.5, 48.5, 53.5, 58.5, 63.5, 68.5, 73.5),
fi = c(29, 127, 143, 33, 33, 36, 34, 32, 31, 2)
)
# Expandir los datos (aproximaciÃ³n)
edad_expandida <- edad %>%
slice(rep(1:n(), fi))
# GrÃ¡fico de densidad
ggplot(educacion, aes(x = Horas)) +
geom_density(fill = "steelblue", alpha = 0.5, size = 1, color = "darkblue") +
labs(
title = "Densidad de probabilidad: Horas de estudio",
x = "Horas",
y = "Densidad"
) +
theme_minimal()
library(ggplot2)
Xmin <- min(educacion$Horas, na.rm = TRUE)
ojiva_data <- educacion %>%
mutate(interv = cut(Horas, breaks = seq(Xmin, Xmin + RC, by = A),
include.lowest = TRUE, right = FALSE)) %>%
group_by(interv) %>%
summarise(fi = n()) %>%
mutate(hi = fi / sum(fi),
Hi = cumsum(hi),
ls = seq(Xmin + A, Xmin + RC, by = A))
# Graficar la ojiva
ggplot(ojiva_data, aes(x = ls, y = Hi)) +
geom_line(color = "blue", size = 1) +
geom_point(color = "red", size = 2) +
labs(
title = "Ojiva de Frecuencia acumulada: Horas de estudio",
x = "Horas (Limites superiores)",
y = "Frecuencia acumulada relativa"
) +
scale_y_continuous(labels = scales::percent) +
theme_minimal()
library(dplyr)
library(kableExtra)
m1 <- Xmin + (A / 2)
educacion <- educacion %>%
mutate(interv = cut(x = Horas,
breaks = seq(Xmin, Xmax, by = A),
include.lowest = TRUE,
right = FALSE))
tabla <- educacion %>%
group_by(Intervalos = interv) %>%
summarise(fi = n()) %>%
mutate(
hi = round(fi / sum(fi), 4),
mi = seq(m1, by = A, length.out = n()),
Fi = cumsum(fi),
Hi = round(cumsum(hi), 4)
)
total_fi <- sum(tabla$fi)
total_hi <- sum(tabla$hi)
tabla_final <- tabla %>%
mutate(across(c(Intervalos, mi, Fi, Hi), as.character)) %>%
add_row(
Intervalos = "Total",
mi = "",
fi = total_fi,
hi = total_hi,
Fi = "",
Hi = ""
) %>%
relocate(Intervalos, mi, fi)
tabla_final %>%
knitr::kable(
col.names = c("Intervalos (Horas)", "mi", "fi", "hi", "Fi", "Hi"),
align = "lrrrrr"
) %>%
kableExtra::kable_styling(full_width = FALSE, position = "center") %>%
kableExtra::add_header_above(c("DistribuciÃ³n de Frecuencias: Variable Horas" = 6))
# Cargar librerÃ­as
library(ggplot2)
library(tibble)
df_acumulado <- educacion %>%
filter(!is.na(Horas)) %>%
count(Horas) %>%
arrange(Horas) %>%
mutate(
hi = n / sum(n),
Hi = cumsum(hi)
) %>%
rename(x = Horas)
ggplot(df_acumulado, aes(x = x, y = Hi)) +
geom_step(direction = "hv", color = "#2C3E50", linewidth = 1.2) +
geom_point(color = "#E74C3C", size = 2.5) +
scale_y_continuous(
limits = c(0, 1.05),
breaks = seq(0, 1, 0.1),
expand = c(0, 0)
) +
labs(
title = "FunciÃ³n de DistribuciÃ³n Acumulada (FDA)",
subtitle = "Variable: Horas de estudio/trabajo",
x = "Horas (x)",
y = "Frecuencia Relativa Acumulada (Hi)",
caption = "Fuente: dataset_educacion_matematica"
) +
theme_minimal(base_size = 14) +
theme(
plot.title = element_text(face = "bold", hjust = 0.5),
panel.grid.minor = element_blank(),
axis.title = element_text(face = "bold"),
panel.grid.major.x = element_line(color = "gray90", linetype = "dashed")
)
df_bastones <- educacion %>%
filter(!is.na(Cursos)) %>%
count(Cursos) %>%
mutate(fx = n / sum(n))
ggplot(df_bastones, aes(x = Cursos, y = fx)) +
# LÃ­neas de los bastones
geom_segment(aes(xend = Cursos, yend = 0),
color = "steelblue",
linewidth = 1.2) +
geom_point(color = "darkred", size = 4, shape = 18) +
geom_text(aes(label = sprintf("%.3f", fx)),
vjust = -1.5,
size = 3.5,
fontface = "bold") +
scale_x_continuous(breaks = seq(min(df_bastones$Cursos), max(df_bastones$Cursos), by = 1)) +
scale_y_continuous(limits = c(0, max(df_bastones$fx) + 0.1),
expand = c(0, 0)) +
labs(
title = "Diagrama de Bastones",
subtitle = "DistribuciÃ³n de Probabilidad: NÃºmero de Cursos Realizados",
x = "NÃºmero de Cursos (Variable Discreta)",
y = "Probabilidad f(x)",
caption = "Fuente: ElaboraciÃ³n propia basada en educacion.xlsx"
) +
theme_minimal() +
theme(
plot.title = element_text(face = "bold", size = 16, color = "#2C3E50"),
axis.title = element_text(face = "bold"),
panel.grid.minor = element_blank()
)
