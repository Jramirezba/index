library(ggplot2)
library(dplyr)
library(readxl)
data_grafico <- educacion %>%
filter(!is.na(Nivel_Educativo), !is.na(Estrato)) %>%
mutate(
Nivel_Educativo = factor(Nivel_Educativo, levels = c("Primaria", "Secundaria", "Universidad")),
Estrato = factor(Estrato, levels = c("Bajo", "Medio", "Alto"))
) %>%
count(Nivel_Educativo, Estrato) %>%
group_by(Nivel_Educativo) %>%
mutate(porcentaje = n / sum(n) * 100)
ggplot(data_grafico, aes(x = Nivel_Educativo, y = porcentaje, fill = Estrato)) +
# geom_col con position = "stack" crea el efecto apilado
geom_col(position = "stack", color = "black", linewidth = 0.3) +
scale_fill_manual(values = c("Bajo" = "#E74C3C", "Medio" = "#F1C40F", "Alto" = "#2980B9")) +
geom_text(
aes(label = sprintf("%.1f%%", porcentaje)),
position = position_stack(vjust = 0.5),
color = "white",
fontface = "bold",
size = 4
) +
labs(
title = "DistribuciÃ³n de Estratos por Nivel Educativo",
subtitle = "GrÃ¡fico de barras apiladas al 100%",
x = "Nivel de EducaciÃ³n",
y = "Porcentaje (%)",
fill = "Estrato Social",
caption = "Fuente: Datos del archivo educacion.xlsx"
) +
theme_minimal() +
theme(
plot.title = element_text(face = "bold", size = 14),
axis.text = element_text(face = "bold"),
legend.position = "right"
)
options(
knitr.table.format = "html",
scipen = 999
)
# Crear la tabla original
tabla <- educacion %>%
group_by(Funcion = Estrato)%>%
summarise(fi = n()) %>%
mutate(hi = round(fi/sum(fi), 4),
Porcentaje = paste0(hi*100, "%"),
Fi = cumsum(fi),
Hi = cumsum(hi)
)
ipak <- function(pkg){
options(repos = c(CRAN = "https://cloud.r-project.org"))
new.pkg <- pkg[!(pkg %in% rownames(installed.packages()))]
if(length(new.pkg)) install.packages(new.pkg, dependencies = TRUE)
invisible(lapply(pkg, function(p)
suppressPackageStartupMessages(library(p, character.only = TRUE))
))
}
packages <- c("tidyverse","kableExtra","readxl",
"palmerpenguins")
ipak(packages)
# Crear la tabla original
tabla <- educacion %>%
group_by(Funcion = Estrato)%>%
summarise(fi = n()) %>%
mutate(hi = round(fi/sum(fi), 4),
Porcentaje = paste0(hi*100, "%"),
Fi = cumsum(fi),
Hi = cumsum(hi)
)
# Convertir las columnas Fucion, Fi, y Hi a character para evitar conflictos
tabla_prep <- tabla %>% mutate(
Funcion = as.character(Funcion),
Fi = as.character(Fi),
Hi = as.character(Hi)
)
# AÃ±adir la fila de totales, dejando Fi y Hi vacÃ­os
totales <- tibble(
Funcion = "Total",
fi = sum(tabla$fi),
hi = round(sum(tabla$hi), 4),
Porcentaje = paste0(round(sum(tabla$hi) * 100, 2), "%"),
Fi = "",  # Puedes dejar en blanco o usar un valor numÃ©rico
Hi = ""   # Puedes dejar en blanco o usar un valor numÃ©rico
)
# Combinar la tabla con los totales
tabla_final <- bind_rows(tabla_prep, totales)
# Mostrar la tabla final con kable
tabla_final %>%
knitr::kable(
col.names = c("Funcion", "fi", "hi", "Porcentaje", "Fi", "Hi"),
align = c("l", "c", "c", "c", "c", "c")
)
# Cargar las librerÃ­as necesarias
library(ggplot2)
library(dplyr)
library(readxl)
funcion_counts <- educacion %>%
filter(!is.na(Estrato)) %>%
# Convertimos a factor para que el orden sea lÃ³gico y no alfabÃ©tico
mutate(Estrato = factor(Estrato, levels = c("Bajo", "Medio", "Alto"))) %>%
group_by(Estrato) %>%
summarise(n = n()) %>%
mutate(porcentaje = n / sum(n) * 100)
ggplot(funcion_counts, aes(x = Estrato, y = porcentaje, fill = Estrato)) +
geom_col(color = "black", linewidth = 0.2) +
scale_fill_brewer(palette = "Blues") +
labs(
title = "DistribuciÃ³n porcentual por Estrato",
subtitle = "Variable Cualitativa Ordinal (Ordenada)",
x = "Estrato SocioeconÃ³mico",
y = "Porcentaje (%)",
caption = "Fuente: ElaboraciÃ³n propia basada en educacion.xlsx"
) +
geom_text(
aes(label = sprintf("%.1f%%", porcentaje)),
vjust = -0.5,
color = "black",
size = 4.5,
fontface = "bold"
) +
scale_y_continuous(limits = c(0, max(funcion_counts$porcentaje) + 10)) +
theme_minimal() +
theme(
legend.position = "none",
plot.title = element_text(face = "bold", size = 14),
axis.text = element_text(face = "bold")
)
