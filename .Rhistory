geom_bar(stat = "identity", width = 1) +
coord_polar("y") +
labs(title = "DistribuciÃ³n porcentual por Genero") +
theme_minimal() +
theme(axis.title.x = element_blank(),
axis.title.y = element_blank(),
panel.grid = element_blank(),
axis.text.x = element_blank()) +
geom_text(aes(label = sprintf("%.1f%%", porcentaje)),
position = position_stack(vjust = 0.5),
color = "white",
size = 5)
# Crear la tabla original'
tabla <- educacion %>%
filter(!is.na(Cursos)) %>%
group_by(x = Cursos) %>%
summarise(fi = n()) %>%
mutate(
hi = round(fi / sum(fi), 4),
Porcentaje = paste0(round(hi * 100, 2), "%"),
Fi = cumsum(fi),
Hi = round(cumsum(hi), 4)
)
tabla_prep <- tabla %>%
mutate(
x = as.character(x),
fi = as.numeric(fi),
hi = as.numeric(hi),
Fi = as.character(Fi),
Hi = as.character(Hi)
)
totales <- tibble(
x = "Total",
fi = sum(tabla$fi),
hi = 1,
Porcentaje = "100%",
Fi = "",
Hi = ""
)
bind_rows(tabla_prep, totales) %>%
kable(
col.names = c("NÃºmero de Cursos (x)", "fi", "hi", "Porcentaje", "Fi", "Hi"),
align = c("l", "c", "c", "c", "c", "c"),
caption = "Tabla de DistribuciÃ³n de Frecuencias: Cantidad de Cursos Realizados"
) %>%
kable_styling(bootstrap_options = c("striped", "hover", "condensed"), full_width = F) %>%
row_spec(nrow(tabla_prep) + 1, bold = TRUE, background = "#F2F2F2")
